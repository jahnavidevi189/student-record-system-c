#include <stdio.h>

struct Student {
    int id;
    char name[50];
    float marks;
};

int main() {
    struct Student s[3];

    // Input data
    for(int i = 0; i < 3; i++) {
        printf("Enter details for student %d\n", i + 1);
        
        printf("ID: ");
        scanf("%d", &s[i].id);
        
        printf("Name: ");
        scanf("%s", s[i].name);
        
        printf("Marks: ");
        scanf("%f", &s[i].marks);
    }

    // Display data
    printf("\n--- Student Records ---\n");
    for(int i = 0; i < 3; i++) {
        printf("\nStudent %d\n", i + 1);
        printf("ID: %d\n", s[i].id);
        printf("Name: %s\n", s[i].name);
        printf("Marks: %.2f\n", s[i].marks);
    }

    return 0;
}
